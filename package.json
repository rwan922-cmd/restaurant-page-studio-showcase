{
  "name": "restaurant-page-studio-showcase",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:cloudflare": "npm run build && WRANGLER_LOG_PATH=.wrangler/wrangler.log wrangler pages dev dist --config wrangler.example.toml --persist-to .wrangler/state --port 8788",
    "build": "tsc --noEmit && vite build",
    "db:migrate:local": "WRANGLER_LOG_PATH=.wrangler/wrangler.log wrangler d1 migrations apply DB --local --config wrangler.example.toml --persist-to .wrangler/state",
    "auth:generate": "node scripts/generate-auth-secrets.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "wrangler": "^4.98.0"
  }
}
